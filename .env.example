# FastGPT service URL
FASTGPT_BASE_URL=http://localhost:3000
FASTGPT_API_KEY=fastgpt-xxxxx

# API Key (caller authentication, separate from FastGPT key)
API_KEY=your-api-key-here

# MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fastgpt_rag

# App port and workers
APP_PORT=8000
APP_WORKERS=4

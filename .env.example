# FastGPT service URL
FASTGPT_BASE_URL=http://localhost:3000
FASTGPT_API_KEY=fastgpt-xxxxx

# AES-256-CBC authentication
# 64-char hex string (32 bytes), generate with: python -c "import os; print(os.urandom(32).hex())"
AES_SECRET_KEY=your-64-char-hex-key-here
# Token timestamp validation window in seconds (default: 300 = 5 minutes)
AES_TOKEN_TTL=300

# MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fastgpt_rag

# App port and workers
APP_PORT=8000
APP_WORKERS=4
